#!/bin/bash
set -e

DRIVER=$(snapctl get driver)
REGISTRY=$(snapctl get registry)
SOCKET_GROUP=$(snapctl get socket-group)
SOCKET_MODE=$(snapctl get socket-mode)
PODMAN_SOCKET=$(snapctl get podman-socket)

# Default to vm if driver is not set
if [ -z "$DRIVER" ]; then
    DRIVER="vm"
fi

# Validate socket mode if set
if [ -n "$SOCKET_MODE" ]; then
    if ! [[ "$SOCKET_MODE" =~ ^06[0-7]{2}$ ]]; then
        echo "Error: Invalid socket-mode: must be a 4-digit octal starting with 06 (e.g. 0660)" >&2
        exit 1
    fi
fi

if [ "$DRIVER" = "k8s" ]; then
    if [ -z "$REGISTRY" ]; then
        echo "Error: Driver k8s requires a registry (e.g., registry=localhost:5000)" >&2
        exit 1
    fi
    
    # Validate registry (allow self-signed or plain HTTP for local test)
    echo "Validating registry at http://$REGISTRY/v2/ ..."
    if ! curl -s -f "http://$REGISTRY/v2/" > /dev/null; then
        echo "Error: Failed to contact registry at http://$REGISTRY/v2/ (HTTP 200 required)" >&2
        exit 1
    fi

    # Attempt to initialize k8s cluster
    echo "Initializing OpenShell Kubernetes Cluster..."
    export KUBECONFIG="/root/.kube/config"
    if ! "$SNAP/bin/openshell" cluster init --registry "$REGISTRY"; then
        echo "Error: Failed to initialize Kubernetes cluster" >&2
        exit 1
    fi
elif [ "$DRIVER" = "podman" ]; then
    if [ -n "$PODMAN_SOCKET" ]; then
        export OPENSHELL_PODMAN_SOCKET="$PODMAN_SOCKET"
    fi
    echo "Initializing Podman driver..."
    if ! "$SNAP/bin/openshell" podman init; then
        echo "Error: Failed to load images into Podman. Make sure the socket is reachable." >&2
        exit 1
    fi
elif [ "$DRIVER" != "vm" ]; then
    echo "Error: Invalid driver '$DRIVER'. Allowed values: vm, k8s, podman" >&2
    exit 1
fi

# Write environment file for the daemon wrapper
mkdir -p "$SNAP_DATA"
cat <<EOF > "$SNAP_DATA/config.env"
DRIVER="${DRIVER}"
REGISTRY="${REGISTRY}"
SOCKET_GROUP="${SOCKET_GROUP}"
SOCKET_MODE="${SOCKET_MODE}"
PODMAN_SOCKET="${PODMAN_SOCKET}"
EOF

# Restart the gateway daemon
snapctl restart openshell.server
