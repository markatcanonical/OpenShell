#!/bin/bash
set -e

# Source the configuration if it exists
if [ -f "$SNAP_DATA/config.env" ]; then
    source "$SNAP_DATA/config.env"
fi

if [ "$DRIVER" = "k8s" ]; then
    echo "Gateway is configured to run on K8s. Exiting local daemon gracefully."
    exit 0
fi

# Ensure writable directories exist
mkdir -p "$SNAP_COMMON/run"
mkdir -p "$SNAP_COMMON/vm-state"

# UDS socket configuration
UDS_ARGS=("--unix-socket-path" "$SNAP_COMMON/run/gateway.sock")
if [ -n "$SOCKET_GROUP" ]; then
    UDS_ARGS+=("--unix-socket-group" "$SOCKET_GROUP")
fi
if [ -n "$SOCKET_MODE" ]; then
    UDS_ARGS+=("--unix-socket-mode" "$SOCKET_MODE")
fi

# Load SSH handshake secret via env var (not CLI arg) to avoid leaking
# the secret in /proc/PID/cmdline. Generated by the install hook and
# persisted in $SNAP_COMMON so it survives snap refreshes.
SSH_SECRET_FILE="$SNAP_COMMON/ssh-handshake-secret"
if [ -f "$SSH_SECRET_FILE" ]; then
    export OPENSHELL_SSH_HANDSHAKE_SECRET="$(cat "$SSH_SECRET_FILE")"
fi

# Gateway port (configurable via: sudo snap set openshell port=NNNN)
PORT="${PORT:-8080}"

exec "$SNAP/bin/openshell-gateway" \
    --db-url "sqlite:$SNAP_DATA/openshell.db" \
    --drivers "${DRIVER:-vm}" \
    --disable-tls \
    --port "$PORT" \
    --grpc-endpoint "http://127.0.0.1:$PORT" \
    --vm-driver-state-dir "$SNAP_COMMON/vm-state" \
    "${UDS_ARGS[@]}" "$@"
