#!/bin/bash
set -e



# Ensure UDS dir exists
mkdir -p "$SNAP_COMMON/run"

UDS_ARGS=("--unix-socket-path" "$SNAP_COMMON/run/gateway.sock")
if [ -n "$SOCKET_GROUP" ]; then
    UDS_ARGS+=("--unix-socket-group" "$SOCKET_GROUP")
fi
SOCKET_MODE="${SOCKET_MODE:-0666}"
UDS_ARGS+=("--unix-socket-mode" "$SOCKET_MODE")

TLS_ARGS=()
if [ -z "$OPENSHELL_TLS_CERT" ] && [ -z "$OPENSHELL_DISABLE_TLS" ]; then
    TLS_ARGS=("--disable-tls")
fi

SSH_SECRET_ARGS=()
if [ -z "$OPENSHELL_SSH_HANDSHAKE_SECRET" ]; then
    SECRET_FILE="$SNAP_DATA/ssh_handshake_secret"
    if [ ! -f "$SECRET_FILE" ]; then
        head -c 32 /dev/urandom | base64 > "$SECRET_FILE"
        chmod 600 "$SECRET_FILE"
    fi
    SSH_SECRET_ARGS=("--ssh-handshake-secret" "$(cat "$SECRET_FILE")")
fi

GRPC_ARGS=()
if [ -z "$OPENSHELL_GRPC_ENDPOINT" ]; then
    SERVER_PORT="${OPENSHELL_SERVER_PORT:-8080}"
    GRPC_ARGS=("--grpc-endpoint" "http://host.containers.internal:${SERVER_PORT}")
fi

if [ -n "$PODMAN_SOCKET" ]; then
    export OPENSHELL_PODMAN_SOCKET="$PODMAN_SOCKET"
fi

exec "$SNAP/bin/openshell-gateway" --db-url "sqlite:$SNAP_DATA/openshell.db" --drivers "${DRIVER:-vm}" "${UDS_ARGS[@]}" "${TLS_ARGS[@]}" "${SSH_SECRET_ARGS[@]}" "${GRPC_ARGS[@]}" "$@"
