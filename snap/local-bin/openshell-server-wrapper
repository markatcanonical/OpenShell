#!/bin/bash
set -e

# Source the configuration if it exists
if [ -f "$SNAP_DATA/config.env" ]; then
    source "$SNAP_DATA/config.env"
fi

if [ "$DRIVER" = "k8s" ]; then
    echo "Gateway is configured to run on K8s. Exiting local daemon gracefully."
    # Exit 0 so snapd doesn't consider it a failure and restart loop it if restart-condition is on-failure
    # By default, daemons with `daemon: simple` restart `on-failure`. Exiting 0 stops it cleanly.
    while true; do
        # We sleep forever because if we exit 0, snapd might still report the service as inactive.
        # But wait, exiting 0 is fine, the service just becomes inactive. If we want it to stay 'active', we sleep.
        # Let's just exit 0. Wait, actually `restart-condition` defaults to `on-failure`, so `exit 0` stops it.
        # Let's use `snapctl stop openshell.server` or just sleep to keep it alive doing nothing?
        # A simple sleep loop is safest to prevent snapd from thinking the service died unexpectedly if we care about it being "active".
        # But actually `exit 0` is the correct way to say "I have gracefully stopped".
        exit 0
    done
fi

# Ensure UDS dir exists
mkdir -p "$SNAP_COMMON/run"

UDS_ARGS=("--unix-socket-path" "$SNAP_COMMON/run/gateway.sock")
if [ -n "$SOCKET_GROUP" ]; then
    UDS_ARGS+=("--unix-socket-group" "$SOCKET_GROUP")
fi
SOCKET_MODE="${SOCKET_MODE:-0666}"
UDS_ARGS+=("--unix-socket-mode" "$SOCKET_MODE")

TLS_ARGS=()
if [ -z "$OPENSHELL_TLS_CERT" ] && [ -z "$OPENSHELL_DISABLE_TLS" ]; then
    TLS_ARGS=("--disable-tls")
fi

SSH_SECRET_ARGS=()
if [ -z "$OPENSHELL_SSH_HANDSHAKE_SECRET" ]; then
    SECRET_FILE="$SNAP_DATA/ssh_handshake_secret"
    if [ ! -f "$SECRET_FILE" ]; then
        head -c 32 /dev/urandom | base64 > "$SECRET_FILE"
        chmod 600 "$SECRET_FILE"
    fi
    SSH_SECRET_ARGS=("--ssh-handshake-secret" "$(cat "$SECRET_FILE")")
fi

GRPC_ARGS=()
if [ -z "$OPENSHELL_GRPC_ENDPOINT" ]; then
    SERVER_PORT="${OPENSHELL_SERVER_PORT:-8080}"
    GRPC_ARGS=("--grpc-endpoint" "http://host.containers.internal:${SERVER_PORT}")
fi

exec "$SNAP/bin/openshell-gateway" --db-url "sqlite:$SNAP_DATA/openshell.db" --drivers "${DRIVER:-vm}" "${UDS_ARGS[@]}" "${TLS_ARGS[@]}" "${SSH_SECRET_ARGS[@]}" "${GRPC_ARGS[@]}" "$@"
